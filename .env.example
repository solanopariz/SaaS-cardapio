# Copie para .env e troque os dois JWT_SECRET.
# Gerar segredo: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cardapio?schema=public"

# Precisam ter 32+ chars e ser DIFERENTES entre si — o boot recusa se forem iguais.
JWT_SECRET_STAFF="troque-isto-por-32-chars-aleatorios-de-verdade"
JWT_SECRET_COMANDA="troque-isto-tambem-e-nao-repita-o-de-cima-jamais"

# URL que vai impressa dentro do QR Code. Em piloto real precisa ser o host
# que o celular do cliente alcanca — nao localhost.
APP_PUBLIC_URL="http://localhost:5173"

PORT=3333
CORS_ORIGIN="http://localhost:5173"
NODE_ENV="development"
